PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/currycircle
JWT_SECRET=currycirclejwtsecret12345
# Optional: Google OAuth settings
# GOOGLE_CLIENT_ID=your-google-client-id

# Firebase Configuration (Required if ./config/firebaseServiceAccountKey.json is not present)
# Option A: Paste the entire content of firebaseServiceAccountKey.json as a single-line string:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
# Option B: Set individual key elements:
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CLIENT_EMAIL=your-firebase-client-email
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
